---
import Footer from "../components/Footer.astro";
import "@fortawesome/fontawesome-free/css/all.min.css";

export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Personal website of Tatsuya Kaneko (catatsuy), CTO at PR TIMES.",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <!--Always force latest IE rendering engine or request Chrome Frame-->
    <meta content="IE=edge,chrome=1" http-equiv="X-UA-Compatible" />
    <meta content="width=device-width,initial-scale=1.0" name="viewport" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f3ede3" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="catatsuy.org" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="google-site-verification"
      content="O9P2VRIeo_-wTzTJJSUe-BCXwy21NxOv2CvaaZM3gM8"
    />
    <link
      href="/favicon.ico"
      rel="icon"
      sizes="16x16 32x32 48x48"
      type="image/vnd.microsoft.icon"
    />
    <link rel="preload" href="/css/ea.css" as="style" />
    <link rel="stylesheet" href="/css/ea.css" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <Footer
      href="https://www.catatsuy.org"
      name="catatsuy"
      repo="https://github.com/catatsuy/catatsuy_org_astro"
    />
    <!-- cf: https://www.kevinzunigacuellar.com/blog/google-analytics-in-astro/ -->
    <script
      type="text/partytown"
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-WZLF1ZEM6T"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-WZLF1ZEM6T");
    </script>
    <script src="/js/ea.js" defer></script>
  </body>
</html>
<style is:global>
  :root {
    --bg: #fcfcfa;
    --surface: #ffffff;
    --text: #171717;
    --muted: #666666;
    --line: #e6e6e1;
    --accent: #1f5ea8;
    --accent-strong: #14447b;
    --heading-font:
      "Avenir Next", "Segoe UI", "Hiragino Sans", "Yu Gothic", "Helvetica Neue",
      sans-serif;
    --body-font:
      "Avenir Next", "Segoe UI", "Hiragino Sans", "Yu Gothic", "Helvetica Neue",
      sans-serif;
    --mono-font:
      Menlo, Monaco, Lucida Console, Liberation Mono, DejaVu Sans Mono,
      Bitstream Vera Sans Mono, Courier New, monospace;
  }

  html {
    font-family: var(--body-font);
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--text);
    line-height: 1.7;
  }

  * {
    box-sizing: border-box;
  }

  *::selection {
    background: rgba(157, 75, 47, 0.16);
  }

  code {
    font-family: var(--mono-font);
  }

  a {
    color: var(--accent);
    text-decoration: none;
    transition: color 160ms ease;
  }

  a:is(:hover, :focus) {
    color: var(--accent-strong);
  }

  img {
    max-width: 100%;
    display: block;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: var(--heading-font);
    line-height: 1.08;
    letter-spacing: 0;
    margin: 0;
  }

  p,
  ul,
  li {
    margin-top: 0;
  }
</style>
