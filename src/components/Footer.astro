---
export interface Props {
  href: string;
  name: string;
  repo: string;
}

const { href, name, repo } = Astro.props;
const currentYear: number = new Date().getFullYear();
---

<footer>
  <div class="copyright">
    Copyright © 2010-{currentYear}
    <a href={href}>{name}</a>.
  </div>
  <div class="source">
    Built with Astro. Source on <a target="_blank" rel="noreferrer" href={repo}
      >GitHub</a
    >.
  </div>
</footer>
<style>
  footer {
    width: min(720px, calc(100% - 2rem));
    margin: 3rem auto 0;
    padding: 1.5rem 0 2.5rem;
    text-align: left;
    line-height: 1.7;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.95rem;
  }

  a {
    color: var(--text);
  }

  .copyright {
    letter-spacing: 0.01em;
  }
</style>
