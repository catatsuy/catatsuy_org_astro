---
export interface Props {
  href: string;
  name: string;
  repo: string;
}

const { href, name, repo } = Astro.props;
const currentYear: number = new Date().getFullYear();
---

<footer>
  <div class="copyright">
    Copyright © 2010-{currentYear}
    <a href={href}>{name}</a>.
  </div>
  <div class="source">
    Built with Astro. Source on <a target="_blank" rel="noreferrer" href={repo}
      >GitHub</a
    >.
  </div>
</footer>
<style>
  footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    width: min(1040px, calc(100% - 2rem));
    margin: 3rem auto 0;
    padding: 1.5rem 0 2.5rem;
    line-height: 1.7;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.95rem;
  }

  a {
    color: var(--text);
  }

  .copyright {
    letter-spacing: 0.01em;
  }

  .source {
    text-align: right;
  }

  @media (max-width: 720px) {
    footer {
      display: block;
      width: min(100%, calc(100% - 1.25rem));
      margin-top: 2rem;
      padding: 1.25rem 0 2rem;
    }

    .source {
      margin-top: 0.25rem;
      text-align: left;
    }
  }
</style>
