---
export interface Props {
  icon: string;
  href: string;
  sns: string;
  handle?: string;
}

const { href, icon, sns, handle } = Astro.props;
---

<li class="social-item">
  <a
    class="social-link"
    href={href}
    target="_blank"
    rel="noreferrer"
    aria-label={`Visit catatsuy's ${sns}`}
  >
    <span class="social-icon" aria-hidden="true">
      <span class={icon}></span>
    </span>
    <span class="social-copy">
      <span class="social-name">{sns}</span>
      {handle && <span class="social-handle">{handle}</span>}
    </span>
  </a>
</li>
<style>
  .social-item {
    list-style: none;
  }

  .social-link {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--line);
  }

  .social-link:is(:hover, :focus-visible) {
    border-color: #cfcfc8;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    font-size: 1rem;
    flex-shrink: 0;
  }

  .social-copy {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .social-name {
    font-weight: 700;
    line-height: 1.4;
    color: var(--text);
  }

  .social-handle {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.4;
  }

  @media (max-width: 720px) {
    .social-link {
      gap: 0.65rem;
      padding: 0.8rem 0;
    }

    .social-copy {
      display: block;
    }

    .social-handle {
      display: block;
      margin-top: 0.1rem;
    }
  }
</style>
